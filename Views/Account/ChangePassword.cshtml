@model MotorsHut.Models.Admin.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .cp-wrap {
        max-width: 980px;
    }

    .cp-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1.6rem;
    }

    .cp-header__left {
        display: flex;
        align-items: center;
        gap: 0.9rem;
    }

    .cp-header__icon {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        background: var(--accent-light);
        border: 1.5px solid rgba(67, 56, 202, 0.22);
        display: grid;
        place-items: center;
        color: var(--accent);
        flex-shrink: 0;
    }

    .cp-header__title {
        margin: 0;
        font-size: 1.45rem;
        line-height: 1.1;
        font-weight: 800;
        color: var(--text);
        letter-spacing: -0.01em;
    }

    .cp-header__sub {
        margin-top: 0.15rem;
        font-size: 0.82rem;
        color: var(--muted2);
        font-weight: 600;
    }

    .cp-back {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.48rem 1rem;
        border-radius: 9px;
        border: 1.5px solid var(--border);
        background: var(--surface);
        color: var(--text-soft);
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 700;
        transition: all 0.18s;
    }

    .cp-back:hover {
        color: var(--accent);
        border-color: var(--border-hover);
        background: var(--accent-light);
    }

    .cp-layout {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 1.2rem;
        align-items: start;
    }

    .cp-card {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 1px 3px rgba(99, 102, 241, 0.05), 0 8px 24px rgba(99, 102, 241, 0.06);
    }

    .cp-card__head {
        padding: 1rem 1.25rem;
        border-bottom: 1.5px solid var(--border);
        background: linear-gradient(to right, #f5f3ff, #eef2ff);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.8rem;
        flex-wrap: wrap;
    }

    .cp-card__title {
        margin: 0;
        font-size: 0.95rem;
        font-weight: 800;
        color: var(--text);
    }

    .cp-card__hint {
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .cp-card__body {
        padding: 1.25rem;
    }

    .cp-alert {
        background: rgba(220, 38, 38, 0.07);
        border: 1.5px solid rgba(220, 38, 38, 0.2);
        border-radius: 10px;
        color: #b91c1c;
        font-size: 0.84rem;
        font-weight: 600;
        padding: 0.7rem 0.9rem;
        margin-bottom: 1rem;
    }

    .cp-alert:empty {
        display: none;
    }

    .cp-field {
        margin-bottom: 1rem;
    }

    .cp-label {
        display: block;
        margin-bottom: 0.42rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-soft);
    }

    .cp-input-wrap {
        position: relative;
    }

    .cp-input-icon {
        position: absolute;
        left: 0.85rem;
        top: 50%;
        transform: translateY(-50%);
        width: 15px;
        height: 15px;
        color: var(--muted);
        pointer-events: none;
        transition: color 0.18s;
    }

    .cp-input {
        width: 100%;
        height: 43px;
        border: 1.5px solid var(--border);
        border-radius: 10px;
        background: var(--bg);
        color: var(--text);
        font-size: 0.9rem;
        font-family: 'Nunito', sans-serif;
        font-weight: 600;
        outline: none;
        padding: 0 2.6rem 0 2.45rem;
        transition: border-color 0.18s, box-shadow 0.18s, background 0.18s;
    }

    .cp-input::placeholder {
        color: #a5b4fc;
        font-weight: 500;
    }

    .cp-input:focus {
        border-color: var(--accent);
        background: #fafbff;
        box-shadow: 0 0 0 3px rgba(67, 56, 202, 0.15);
    }

    .cp-input-wrap:focus-within .cp-input-icon {
        color: var(--accent);
    }

    .cp-input.input-validation-error {
        border-color: rgba(220, 38, 38, 0.35);
        background: rgba(220, 38, 38, 0.05);
    }

    .cp-eye {
        position: absolute;
        right: 0.72rem;
        top: 50%;
        transform: translateY(-50%);
        border: none;
        background: transparent;
        color: var(--muted);
        cursor: pointer;
        display: grid;
        place-items: center;
        padding: 0.2rem;
        transition: color 0.18s;
    }

    .cp-eye:hover {
        color: var(--accent);
    }

    .cp-eye svg {
        width: 15px;
        height: 15px;
    }

    .cp-field-error {
        display: block;
        margin-top: 0.35rem;
        font-size: 0.76rem;
        color: #dc2626;
        font-weight: 600;
    }

    .cp-strength {
        margin-top: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.55rem;
    }

    .cp-strength__bars {
        display: flex;
        gap: 4px;
        flex: 1;
    }

    .cp-strength__bar {
        height: 4px;
        flex: 1;
        border-radius: 99px;
        background: var(--border);
        transition: background 0.28s;
    }

    .cp-strength__bar.active-weak { background: #ef4444; }
    .cp-strength__bar.active-fair { background: #f59e0b; }
    .cp-strength__bar.active-good { background: #10b981; }
    .cp-strength__bar.active-strong { background: #059669; }

    .cp-strength__label {
        min-width: 44px;
        text-align: right;
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--muted2);
    }

    .cp-actions {
        margin-top: 1.15rem;
        display: flex;
        gap: 0.7rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .cp-submit {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        border: none;
        border-radius: 10px;
        padding: 0.72rem 1.3rem;
        background: linear-gradient(135deg, #3730a3, #4338ca, #4f46e5);
        color: #ffffff;
        font-size: 0.88rem;
        font-weight: 800;
        font-family: 'Nunito', sans-serif;
        box-shadow: 0 6px 18px rgba(67, 56, 202, 0.3);
        transition: transform 0.16s, filter 0.18s, box-shadow 0.18s;
    }

    .cp-submit:hover {
        transform: translateY(-1px);
        filter: brightness(1.06);
        box-shadow: 0 9px 24px rgba(67, 56, 202, 0.36);
    }

    .cp-cancel {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border: 1.5px solid var(--border);
        border-radius: 10px;
        padding: 0.68rem 1rem;
        color: var(--text-soft);
        background: var(--surface);
        text-decoration: none;
        font-size: 0.84rem;
        font-weight: 700;
        transition: all 0.18s;
    }

    .cp-cancel:hover {
        color: var(--accent);
        border-color: var(--border-hover);
        background: var(--accent-light);
    }

    .cp-side {
        display: grid;
        gap: 1rem;
    }

    .cp-info {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
    }

    .cp-info__head {
        background: linear-gradient(to right, #f5f3ff, #eef2ff);
        border-bottom: 1.5px solid var(--border);
        padding: 0.72rem 1rem;
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
    }

    .cp-info__body {
        padding: 0.95rem 1rem;
    }

    .cp-list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.55rem;
    }

    .cp-list li {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        font-size: 0.8rem;
        color: var(--text-soft);
        font-weight: 600;
        line-height: 1.5;
    }

    .cp-list__dot {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: var(--accent-light);
        border: 1.5px solid rgba(67, 56, 202, 0.22);
        color: var(--accent);
        display: grid;
        place-items: center;
        flex-shrink: 0;
        margin-top: 1px;
    }

    @@media (max-width: 860px) {
        .cp-layout {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="cp-wrap">
    <div class="cp-header">
        <div class="cp-header__left">
            <div class="cp-header__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
            </div>
            <div>
                <h1 class="cp-header__title">Change Password</h1>
                <p class="cp-header__sub">Update your administrator credentials securely.</p>
            </div>
        </div>

        <a asp-controller="Admin" asp-action="Dashboard" class="cp-back">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to Dashboard
        </a>
    </div>

    <div class="cp-layout">
        <section class="cp-card">
            <div class="cp-card__head">
                <h2 class="cp-card__title">Security Settings</h2>
                <span class="cp-card__hint">Admin Account</span>
            </div>

            <div class="cp-card__body">
                <form asp-action="ChangePassword" asp-controller="Account" method="post" novalidate id="cpForm">
                    <div asp-validation-summary="ModelOnly" class="cp-alert"></div>

                    <div class="cp-field">
                        <label asp-for="CurrentPassword" class="cp-label">Current Password</label>
                        <div class="cp-input-wrap">
                            <input asp-for="CurrentPassword" class="cp-input" type="password" placeholder="Enter your current password" id="currentPwd" />
                            <svg class="cp-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                            <button type="button" class="cp-eye" onclick="togglePwd('currentPwd', this)" aria-label="Toggle visibility">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="CurrentPassword" class="cp-field-error"></span>
                    </div>

                    <div class="cp-field">
                        <label asp-for="NewPassword" class="cp-label">New Password</label>
                        <div class="cp-input-wrap">
                            <input asp-for="NewPassword" class="cp-input" type="password" placeholder="Create a strong password" id="newPwd" oninput="updateStrength(this.value)" />
                            <svg class="cp-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            </svg>
                            <button type="button" class="cp-eye" onclick="togglePwd('newPwd', this)" aria-label="Toggle visibility">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                        </div>

                        <div class="cp-strength" id="strengthMeter" style="display:none">
                            <div class="cp-strength__bars">
                                <div class="cp-strength__bar" id="sb1"></div>
                                <div class="cp-strength__bar" id="sb2"></div>
                                <div class="cp-strength__bar" id="sb3"></div>
                                <div class="cp-strength__bar" id="sb4"></div>
                            </div>
                            <span class="cp-strength__label" id="strengthLabel"></span>
                        </div>
                        <span asp-validation-for="NewPassword" class="cp-field-error"></span>
                    </div>

                    <div class="cp-field">
                        <label asp-for="ConfirmPassword" class="cp-label">Confirm New Password</label>
                        <div class="cp-input-wrap">
                            <input asp-for="ConfirmPassword" class="cp-input" type="password" placeholder="Repeat your new password" id="confirmPwd" />
                            <svg class="cp-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                            </svg>
                            <button type="button" class="cp-eye" onclick="togglePwd('confirmPwd', this)" aria-label="Toggle visibility">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="cp-field-error"></span>
                    </div>

                    <div class="cp-actions">
                        <button type="submit" class="cp-submit">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v14a2 2 0 0 1-2 2z"/>
                                <polyline points="17 21 17 13 7 13 7 21"/>
                                <polyline points="7 3 7 8 15 8"/>
                            </svg>
                            Update Password
                        </button>

                        <a asp-controller="Admin" asp-action="Dashboard" class="cp-cancel">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </section>

        <aside class="cp-side">
            <div class="cp-info">
                <div class="cp-info__head">Password Guidance</div>
                <div class="cp-info__body">
                    <ul class="cp-list">
                        <li><span class="cp-list__dot"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>Use at least 8 characters.</li>
                        <li><span class="cp-list__dot"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>Include uppercase and lowercase letters.</li>
                        <li><span class="cp-list__dot"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>Add numbers and a special character.</li>
                        <li><span class="cp-list__dot"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>Avoid reusing old passwords.</li>
                    </ul>
                </div>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePwd(inputId, btn) {
            const input = document.getElementById(inputId);
            const isHidden = input.type === 'password';
            input.type = isHidden ? 'text' : 'password';
            btn.innerHTML = isHidden
                ? `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`
                : `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="15" height="15"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`;
        }

        function updateStrength(value) {
            const meter = document.getElementById('strengthMeter');
            const label = document.getElementById('strengthLabel');
            const bars = [
                document.getElementById('sb1'),
                document.getElementById('sb2'),
                document.getElementById('sb3'),
                document.getElementById('sb4')
            ];

            if (!value) {
                meter.style.display = 'none';
                return;
            }

            meter.style.display = 'flex';

            let score = 0;
            if (value.length >= 8) score++;
            if (/[A-Z]/.test(value)) score++;
            if (/[0-9]/.test(value)) score++;
            if (/[^A-Za-z0-9]/.test(value)) score++;

            const levels = ['', 'Weak', 'Fair', 'Good', 'Strong'];
            const cls = ['', 'active-weak', 'active-fair', 'active-good', 'active-strong'];
            const colors = ['', '#ef4444', '#f59e0b', '#10b981', '#059669'];

            bars.forEach((bar, index) => {
                bar.className = 'cp-strength__bar' + (index < score ? ` ${cls[score]}` : '');
            });

            label.textContent = levels[score];
            label.style.color = colors[score];
        }
    </script>
}
