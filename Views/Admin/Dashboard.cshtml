@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    :root {
        --ind-surface:    #ffffff;
        --ind-surface2:   #eef2ff;
        --ind-border:     #e0e7ff;
        --ind-text:       #1e1b4b;
        --ind-muted:      #6366f1;
        --ind-muted2:     #818cf8;
        --ind-accent:     #4338ca;
        --ind-accent2:    #6366f1;
        --ind-green:      #10b981;
        --ind-red:        #f87171;
        --ind-amber:      #f59e0b;
        --ind-blue:       #3b82f6;
        --ind-bg:         #eef2ff;
    }

    /* ═══════════════════════════════
       ENTRANCE ANIMATIONS
    ═══════════════════════════════ */
    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(18px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to   { opacity: 1; }
    }

    @@keyframes scaleIn {
        from { opacity: 0; transform: scale(0.93); }
        to   { opacity: 1; transform: scale(1); }
    }

    @@keyframes countUp {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@keyframes shimmer {
        0%   { background-position: -200% center; }
        100% { background-position:  200% center; }
    }

    @@keyframes livePulse {
        0%,100% { box-shadow: 0 0 0 4px rgba(16,185,129,0.18); }
        50%      { box-shadow: 0 0 0 9px rgba(16,185,129,0.05); }
    }

    @@keyframes barGrow {
        from { height: 0 !important; }
    }

    @@keyframes dotBounce {
        0%, 80%, 100% { transform: scale(1); }
        40% { transform: scale(1.35); }
    }

    @@keyframes slideRight {
        from { width: 0; }
    }

    @@keyframes activityIn {
        from { opacity: 0; transform: translateX(-14px); }
        to   { opacity: 1; transform: translateX(0); }
    }

    /* ═══════════════════════════════
       HEADER
    ═══════════════════════════════ */
    .db-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2rem;
        animation: fadeUp 0.5s cubic-bezier(0.22,1,0.36,1) both;
    }

    .db-header__eyebrow {
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--ind-muted2);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.35rem;
    }

    .db-header__eyebrow-line {
        height: 1.5px;
        width: 24px;
        background: linear-gradient(90deg, var(--ind-muted2), transparent);
        border-radius: 99px;
    }

    .db-header__title {
        font-size: 2rem;
        font-weight: 900;
        color: var(--ind-text);
        line-height: 1.05;
        margin: 0 0 0.35rem;
        letter-spacing: -0.03em;
    }

    .db-header__title span {
        background: linear-gradient(135deg, #3730a3, #6366f1, #818cf8);
        background-size: 200% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: shimmer 3s linear infinite;
    }

    .db-header__sub {
        font-size: 0.86rem;
        color: var(--ind-muted2);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
    }

    .live-dot {
        width: 7px; height: 7px;
        border-radius: 50%;
        background: var(--ind-green);
        box-shadow: 0 0 0 4px rgba(16,185,129,0.18);
        animation: livePulse 2s ease infinite;
        flex-shrink: 0;
    }

    .db-header__right {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .db-header__date {
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--ind-accent);
        background: var(--ind-surface);
        border: 1.5px solid var(--ind-border);
        border-radius: 10px;
        padding: 0.48rem 1.1rem;
        white-space: nowrap;
    }

    .db-header__refresh {
        width: 36px; height: 36px;
        background: var(--ind-surface);
        border: 1.5px solid var(--ind-border);
        border-radius: 10px;
        display: grid;
        place-items: center;
        color: var(--ind-muted2);
        cursor: pointer;
        transition: all 0.18s;
    }

    .db-header__refresh:hover {
        color: var(--ind-accent);
        background: var(--ind-surface2);
        border-color: rgba(99,102,241,0.3);
        transform: rotate(180deg);
    }

    /* ═══════════════════════════════
       STAT CARDS
    ═══════════════════════════════ */
    .db-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin-bottom: 1.4rem;
    }

    .db-stat {
        background: var(--ind-surface);
        border: 1.5px solid var(--ind-border);
        border-radius: 18px;
        padding: 1.35rem 1.4rem;
        position: relative;
        overflow: hidden;
        cursor: default;
        animation: scaleIn 0.45s cubic-bezier(0.22,1,0.36,1) both;
        transition: transform 0.22s, box-shadow 0.22s, border-color 0.22s;
    }

    .db-stat:nth-child(1) { animation-delay: 0.08s; }
    .db-stat:nth-child(2) { animation-delay: 0.14s; }
    .db-stat:nth-child(3) { animation-delay: 0.20s; }
    .db-stat:nth-child(4) { animation-delay: 0.26s; }

    .db-stat:hover {
        transform: translateY(-5px);
        box-shadow: 0 16px 40px rgba(67,56,202,0.12);
        border-color: rgba(99,102,241,0.35);
    }

    /* Decorative corner glow */
    .db-stat::before {
        content: '';
        position: absolute;
        top: -40px; right: -40px;
        width: 110px; height: 110px;
        border-radius: 50%;
        background: radial-gradient(circle, var(--stat-glow, rgba(99,102,241,0.12)), transparent 70%);
        pointer-events: none;
        transition: transform 0.4s;
    }

    .db-stat:hover::before { transform: scale(1.3); }

    /* Bottom accent stripe */
    .db-stat::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 3px;
        background: var(--stat-stripe, linear-gradient(90deg, #4338ca, #818cf8));
        border-radius: 0 0 18px 18px;
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.35s cubic-bezier(0.22,1,0.36,1);
    }

    .db-stat:hover::after { transform: scaleX(1); }

    .db-stat--indigo { --stat-glow: rgba(99,102,241,0.12);  --stat-stripe: linear-gradient(90deg, #4338ca, #818cf8); }
    .db-stat--green  { --stat-glow: rgba(16,185,129,0.12);  --stat-stripe: linear-gradient(90deg, #059669, #34d399); }
    .db-stat--blue   { --stat-glow: rgba(59,130,246,0.12);  --stat-stripe: linear-gradient(90deg, #1d4ed8, #60a5fa); }
    .db-stat--red    { --stat-glow: rgba(248,113,113,0.12); --stat-stripe: linear-gradient(90deg, #dc2626, #fca5a5); }

    .db-stat__top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
    }

    .db-stat__label {
        font-size: 0.74rem;
        font-weight: 800;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        color: var(--ind-muted2);
    }

    .db-stat__icon {
        width: 38px; height: 38px;
        border-radius: 11px;
        display: grid;
        place-items: center;
        flex-shrink: 0;
        transition: transform 0.22s;
    }

    .db-stat:hover .db-stat__icon { transform: scale(1.12) rotate(-5deg); }

    .db-stat--indigo .db-stat__icon { background: rgba(99,102,241,0.1);  color: var(--ind-accent2); }
    .db-stat--green  .db-stat__icon { background: rgba(16,185,129,0.1);  color: var(--ind-green); }
    .db-stat--blue   .db-stat__icon { background: rgba(59,130,246,0.1);  color: var(--ind-blue); }
    .db-stat--red    .db-stat__icon { background: rgba(248,113,113,0.1); color: var(--ind-red); }

    .db-stat__value {
        font-size: 2.4rem;
        font-weight: 900;
        color: var(--ind-text);
        line-height: 1;
        margin-bottom: 0.5rem;
        letter-spacing: -0.03em;
        animation: countUp 0.6s cubic-bezier(0.22,1,0.36,1) both;
        animation-delay: 0.3s;
    }

    .db-stat__foot {
        font-size: 0.79rem;
        color: var(--ind-muted2);
        display: flex;
        align-items: center;
        gap: 0.45rem;
        flex-wrap: wrap;
        font-weight: 500;
    }

    .db-stat__trend {
        font-size: 0.72rem;
        font-weight: 800;
        padding: 0.15rem 0.5rem;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        gap: 0.15rem;
    }

    .db-stat__trend--up   { background: rgba(16,185,129,0.1);  color: #059669; }
    .db-stat__trend--down { background: rgba(248,113,113,0.1); color: #dc2626; }

    /* Mini sparkline inside stat */
    .db-stat__spark {
        position: absolute;
        bottom: 14px;
        right: 14px;
        opacity: 0.18;
        pointer-events: none;
        transition: opacity 0.22s;
    }

    .db-stat:hover .db-stat__spark { opacity: 0.32; }

    /* ═══════════════════════════════
       MIDDLE ROW
    ═══════════════════════════════ */
    .db-mid {
        display: grid;
        grid-template-columns: 1.45fr 1fr;
        gap: 1rem;
        margin-bottom: 1.4rem;
    }

    /* Panel */
    .db-panel {
        background: var(--ind-surface);
        border: 1.5px solid var(--ind-border);
        border-radius: 18px;
        overflow: hidden;
        animation: fadeUp 0.5s cubic-bezier(0.22,1,0.36,1) both;
        transition: box-shadow 0.22s, border-color 0.22s;
    }

    .db-panel:hover {
        box-shadow: 0 10px 34px rgba(67,56,202,0.09);
        border-color: rgba(99,102,241,0.25);
    }

    .db-panel__head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.1rem 1.45rem;
        border-bottom: 1.5px solid var(--ind-border);
        background: linear-gradient(to right, #f8f7ff, #f0f4ff);
    }

    .db-panel__title {
        font-size: 0.97rem;
        font-weight: 800;
        color: var(--ind-text);
        margin: 0;
        letter-spacing: -0.01em;
        display: flex;
        align-items: center;
        gap: 0.55rem;
    }

    .db-panel__title-icon {
        width: 26px; height: 26px;
        background: rgba(99,102,241,0.1);
        border: 1px solid rgba(99,102,241,0.18);
        border-radius: 7px;
        display: grid;
        place-items: center;
        color: var(--ind-accent);
    }

    .db-panel__badge {
        font-size: 0.7rem;
        font-weight: 800;
        padding: 0.22rem 0.7rem;
        border-radius: 999px;
        background: rgba(99,102,241,0.1);
        border: 1px solid rgba(99,102,241,0.2);
        color: var(--ind-accent2);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .db-panel__badge-dot {
        width: 5px; height: 5px;
        border-radius: 50%;
        background: var(--ind-green);
        animation: livePulse 2s infinite;
    }

    .db-panel__body { padding: 1.35rem 1.45rem; }

    /* ── BAR CHART ── */
    .db-chart { display: flex; flex-direction: column; gap: 1rem; }

    .db-bars {
        display: flex;
        align-items: flex-end;
        gap: 0.55rem;
        height: 140px;
    }

    .db-bar-col {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.45rem;
        height: 100%;
        justify-content: flex-end;
    }

    .db-bar-wrap {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-end;
        height: 100%;
        position: relative;
    }

    .db-bar {
        width: 100%;
        border-radius: 8px 8px 0 0;
        background: linear-gradient(180deg, #818cf8 0%, #4338ca 100%);
        position: relative;
        cursor: pointer;
        animation: barGrow 0.7s cubic-bezier(0.34,1.56,0.64,1) both;
        transition: filter 0.2s, transform 0.2s;
        min-height: 4px;
    }

    .db-bar:nth-child(1) { animation-delay: 0.1s; }
    .db-bar-col:nth-child(2) .db-bar { animation-delay: 0.15s; }
    .db-bar-col:nth-child(3) .db-bar { animation-delay: 0.2s; }
    .db-bar-col:nth-child(4) .db-bar { animation-delay: 0.25s; }
    .db-bar-col:nth-child(5) .db-bar { animation-delay: 0.3s; }
    .db-bar-col:nth-child(6) .db-bar { animation-delay: 0.35s; }
    .db-bar-col:nth-child(7) .db-bar { animation-delay: 0.4s; }

    .db-bar:hover { filter: brightness(1.15); transform: scaleY(1.04); transform-origin: bottom; }

    /* Tooltip */
    .db-bar-tip {
        position: absolute;
        top: -34px; left: 50%;
        transform: translateX(-50%);
        font-size: 0.67rem;
        font-weight: 800;
        color: var(--ind-accent);
        white-space: nowrap;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.18s;
        background: var(--ind-surface);
        border: 1.5px solid var(--ind-border);
        padding: 3px 7px;
        border-radius: 6px;
        box-shadow: 0 4px 12px rgba(67,56,202,0.1);
    }

    .db-bar:hover .db-bar-tip { opacity: 1; }

    .db-bar-day {
        font-size: 0.69rem;
        color: var(--ind-muted2);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .db-chart__meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 0.85rem;
        border-top: 1.5px solid var(--ind-border);
    }

    .db-chart__total {
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--ind-text);
        letter-spacing: -0.02em;
    }

    .db-chart__sub {
        font-size: 0.75rem;
        color: var(--ind-muted2);
        margin-top: 2px;
        font-weight: 500;
    }

    .db-chart__growth {
        font-size: 0.8rem;
        font-weight: 800;
        color: var(--ind-green);
        background: rgba(16,185,129,0.1);
        border: 1px solid rgba(16,185,129,0.2);
        padding: 0.28rem 0.75rem;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    /* ── ACTIVITY ── */
    .db-activity { display: flex; flex-direction: column; }

    .db-activity__item {
        display: flex;
        align-items: flex-start;
        gap: 0.85rem;
        padding: 0.85rem 0;
        border-bottom: 1.5px solid var(--ind-border);
        animation: activityIn 0.45s cubic-bezier(0.22,1,0.36,1) both;
        transition: background 0.15s;
    }

    .db-activity__item:nth-child(1) { animation-delay: 0.2s; }
    .db-activity__item:nth-child(2) { animation-delay: 0.28s; }
    .db-activity__item:nth-child(3) { animation-delay: 0.36s; }
    .db-activity__item:nth-child(4) { animation-delay: 0.44s; }

    .db-activity__item:last-child { border-bottom: none; }

    .db-activity__item:hover { background: #fafbff; margin: 0 -1.45rem; padding: 0.85rem 1.45rem; border-radius: 8px; }

    .db-activity__dot {
        width: 32px; height: 32px;
        border-radius: 10px;
        display: grid;
        place-items: center;
        flex-shrink: 0;
        margin-top: 1px;
        transition: transform 0.22s;
    }

    .db-activity__item:hover .db-activity__dot { transform: scale(1.1); }

    .db-activity__dot--green { background: rgba(16,185,129,0.1);  color: var(--ind-green); }
    .db-activity__dot--amber { background: rgba(245,158,11,0.1);  color: var(--ind-amber); }
    .db-activity__dot--red   { background: rgba(248,113,113,0.1); color: var(--ind-red); }
    .db-activity__dot--blue  { background: rgba(59,130,246,0.1);  color: var(--ind-blue); }

    .db-activity__text {
        font-size: 0.875rem;
        color: var(--ind-muted);
        line-height: 1.45;
        flex: 1;
        font-weight: 500;
    }

    .db-activity__text strong { color: var(--ind-text); font-weight: 800; }

    .db-activity__time {
        font-size: 0.72rem;
        color: var(--ind-muted2);
        white-space: nowrap;
        margin-top: 2px;
        font-weight: 600;
        background: var(--ind-surface2);
        padding: 0.12rem 0.5rem;
        border-radius: 5px;
    }

    /* ═══════════════════════════════
       BOTTOM ROW
    ═══════════════════════════════ */
    .db-bottom {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    /* ── QUICK ACTIONS ── */
    .db-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.6rem;
    }

    .db-action {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        padding: 0.82rem 1rem;
        border-radius: 12px;
        font-size: 0.875rem;
        font-weight: 700;
        text-decoration: none;
        border: 1.5px solid var(--ind-border);
        background: var(--ind-surface2);
        color: var(--ind-accent);
        transition: all 0.18s cubic-bezier(0.22,1,0.36,1);
        cursor: pointer;
        font-family: 'Nunito', sans-serif;
        width: 100%;
        text-align: left;
        position: relative;
        overflow: hidden;
    }

    .db-action::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.5), transparent);
        opacity: 0;
        transition: opacity 0.18s;
    }

    .db-action:hover::before { opacity: 1; }

    .db-action:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 18px rgba(67,56,202,0.14);
        border-color: rgba(99,102,241,0.3);
        color: var(--ind-text);
        background: #e8eeff;
    }

    .db-action--primary {
        background: linear-gradient(135deg, #312e81, #4338ca, #6366f1);
        color: #fff;
        border-color: transparent;
        box-shadow: 0 4px 18px rgba(67,56,202,0.28);
    }

    .db-action--primary:hover {
        color: #fff;
        filter: brightness(1.08);
        border-color: transparent;
        transform: translateY(-3px);
        box-shadow: 0 10px 28px rgba(67,56,202,0.38);
        background: linear-gradient(135deg, #312e81, #4338ca, #6366f1);
    }

    .db-action--danger {
        color: var(--ind-red);
        border-color: rgba(248,113,113,0.2);
        background: #fff5f5;
    }

    .db-action--danger:hover {
        background: rgba(248,113,113,0.08);
        border-color: rgba(248,113,113,0.35);
        color: #dc2626;
        box-shadow: 0 6px 18px rgba(248,113,113,0.12);
    }

    .db-action__icon {
        width: 30px; height: 30px;
        border-radius: 8px;
        background: rgba(67,56,202,0.1);
        display: grid;
        place-items: center;
        flex-shrink: 0;
        transition: transform 0.22s;
    }

    .db-action:hover .db-action__icon { transform: scale(1.12); }

    .db-action--primary .db-action__icon { background: rgba(255,255,255,0.18); color: #fff; }
    .db-action--danger  .db-action__icon { background: rgba(248,113,113,0.12); color: var(--ind-red); }
    .db-action-form { display: contents; }

    /* ── PERFORMANCE ── */
    .db-perf { display: flex; flex-direction: column; gap: 1.05rem; }

    .db-perf__row {
        display: flex;
        flex-direction: column;
        gap: 0.42rem;
        animation: fadeUp 0.5s cubic-bezier(0.22,1,0.36,1) both;
    }

    .db-perf__row:nth-child(1) { animation-delay: 0.2s; }
    .db-perf__row:nth-child(2) { animation-delay: 0.28s; }
    .db-perf__row:nth-child(3) { animation-delay: 0.36s; }
    .db-perf__row:nth-child(4) { animation-delay: 0.44s; }

    .db-perf__label-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .db-perf__label { font-size: 0.84rem; color: var(--ind-muted); font-weight: 700; }

    .db-perf__pct {
        font-size: 0.84rem;
        font-weight: 900;
        color: var(--ind-text);
        background: var(--ind-surface2);
        padding: 0.1rem 0.55rem;
        border-radius: 6px;
        border: 1px solid var(--ind-border);
    }

    .db-perf__track {
        height: 8px;
        background: var(--ind-surface2);
        border-radius: 999px;
        overflow: hidden;
        border: 1px solid var(--ind-border);
        position: relative;
    }

    .db-perf__fill {
        height: 100%;
        border-radius: 999px;
        width: 0;
        transition: width 1.4s cubic-bezier(0.34,1.56,0.64,1);
        position: relative;
    }

    /* Shine effect on fills */
    .db-perf__fill::after {
        content: '';
        position: absolute;
        top: 0; left: -50%; bottom: 0;
        width: 50%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
        animation: shimmer 2.5s 1.6s infinite;
    }

    .db-perf__fill--indigo { background: linear-gradient(90deg, #312e81, #818cf8); }
    .db-perf__fill--green  { background: linear-gradient(90deg, #059669, #34d399); }
    .db-perf__fill--blue   { background: linear-gradient(90deg, #1d4ed8, #60a5fa); }
    .db-perf__fill--red    { background: linear-gradient(90deg, #dc2626, #fca5a5); }

    /* ═══════════════════════════════
       ANIMATION DELAYS FOR PANELS
    ═══════════════════════════════ */
    .db-mid .db-panel:nth-child(1) { animation-delay: 0.18s; }
    .db-mid .db-panel:nth-child(2) { animation-delay: 0.24s; }
    .db-bottom .db-panel:nth-child(1) { animation-delay: 0.3s; }
