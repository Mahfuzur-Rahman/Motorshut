@model MotorsHut.Models.Admin.CarsListViewModel
@{
    ViewData["Title"] = "Cars";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var totalCars = Model.Cars.Count;
    var soldCars = Model.Cars.Count(c => c.IsSold);
    var inStockCars = totalCars - soldCars;
}

<style>
    .cars-page {
        display: grid;
        gap: 1.2rem;
    }

    .cars-hero {
        position: relative;
        overflow: hidden;
        border: 1.5px solid var(--border);
        border-radius: 18px;
        background:
            radial-gradient(circle at top right, rgba(79, 70, 229, 0.18), transparent 55%),
            linear-gradient(135deg, #ffffff 0%, #eef2ff 100%);
        padding: 1.35rem;
    }

    .cars-hero__head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .cars-hero__label {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #6366f1;
    }

    .cars-hero__label::before {
        content: "";
        width: 16px;
        height: 2px;
        border-radius: 2px;
        background: linear-gradient(90deg, #4f46e5, #7c3aed);
    }

    .cars-hero__title {
        margin: 0.3rem 0 0.35rem;
        font-size: clamp(1.6rem, 2.3vw, 2rem);
        line-height: 1.1;
        font-weight: 800;
        color: #1e1b4b;
    }

    .cars-hero__sub {
        margin: 0;
        font-size: 0.93rem;
        color: #4c1d95;
        opacity: 0.85;
        max-width: 680px;
    }

    .cars-btn-add {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 0.86rem;
        font-weight: 800;
        letter-spacing: 0.02em;
        padding: 0.58rem 1.05rem;
        border-radius: 10px;
        text-decoration: none;
        color: #ffffff;
        background: linear-gradient(135deg, #4338ca, #7c3aed);
        box-shadow: 0 8px 22px rgba(67, 56, 202, 0.22);
        border: none;
        transition: transform 0.16s, box-shadow 0.18s, filter 0.18s;
        white-space: nowrap;
    }

    .cars-btn-add:hover {
        color: #ffffff;
        transform: translateY(-1px);
        filter: brightness(1.04);
        box-shadow: 0 12px 28px rgba(67, 56, 202, 0.28);
    }

    .cars-metrics {
        display: grid;
        grid-template-columns: repeat(3, minmax(120px, 1fr));
        gap: 0.8rem;
    }

    .cars-metric {
        border: 1.5px solid var(--border);
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.9);
        padding: 0.72rem 0.82rem;
    }

    .cars-metric span {
        display: block;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6366f1;
    }

    .cars-metric strong {
        display: block;
        margin-top: 0.18rem;
        font-size: 1.35rem;
        line-height: 1;
        color: #1e1b4b;
        font-weight: 800;
    }

    .cars-filter {
        border: 1.5px solid var(--border);
        border-radius: 14px;
        background: var(--surface);
        padding: 0.95rem;
        display: flex;
        align-items: center;
        gap: 0.65rem;
        flex-wrap: wrap;
    }

    .cars-filter__input-wrap {
        position: relative;
        flex: 1;
        min-width: 240px;
    }

    .cars-filter__icon {
        position: absolute;
        left: 0.82rem;
        top: 50%;
        transform: translateY(-50%);
        color: #818cf8;
        pointer-events: none;
    }

    .cars-filter__input {
        width: 100%;
        height: 42px;
        border: 1.5px solid var(--border);
        border-radius: 10px;
        background: #ffffff;
        padding: 0 0.85rem 0 2.4rem;
        color: #1e1b4b;
        font-size: 0.9rem;
        font-family: 'Nunito', sans-serif;
        outline: none;
        transition: border-color 0.18s, box-shadow 0.18s;
    }

    .cars-filter__input::placeholder {
        color: #a5b4fc;
    }

    .cars-filter__input:focus {
        border-color: #818cf8;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
    }

    .cars-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.38rem;
        height: 42px;
        padding: 0 0.95rem;
        border-radius: 10px;
        text-decoration: none;
        border: 1.5px solid var(--border);
        font-size: 0.83rem;
        font-weight: 700;
        font-family: 'Nunito', sans-serif;
        white-space: nowrap;
        transition: color 0.18s, background 0.18s, border-color 0.18s;
    }

    .cars-btn--search {
        color: #ffffff;
        background: #4f46e5;
        border-color: #4f46e5;
    }

    .cars-btn--search:hover {
        color: #ffffff;
        background: #4338ca;
        border-color: #4338ca;
    }

    .cars-btn--clear {
        color: #4338ca;
        background: #ffffff;
    }

    .cars-btn--clear:hover {
        color: #312e81;
        background: rgba(224, 231, 255, 0.45);
        border-color: #a5b4fc;
    }

    .cars-panel {
        border: 1.5px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        background: var(--surface);
    }

    .cars-panel__head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.8rem;
        flex-wrap: wrap;
        padding: 1rem 1.15rem;
        border-bottom: 1.5px solid var(--border);
        background: linear-gradient(180deg, #ffffff 0%, #f8faff 100%);
    }

    .cars-panel__title {
        margin: 0;
        font-size: 1rem;
        font-weight: 800;
        color: #1e1b4b;
    }

    .cars-search-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.42rem;
        font-size: 0.77rem;
        font-weight: 700;
        color: #4338ca;
        border: 1px solid #c7d2fe;
        border-radius: 999px;
        background: #eef2ff;
        padding: 0.22rem 0.62rem;
    }

    .cars-search-tag a {
        color: #6366f1;
        text-decoration: none;
    }

    .cars-search-tag a:hover {
        color: #312e81;
    }

    .cars-count {
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #4338ca;
        border: 1px solid #c7d2fe;
        border-radius: 999px;
        background: #eef2ff;
        padding: 0.3rem 0.72rem;
    }

    .cars-empty {
        text-align: center;
        padding: 3.2rem 1.2rem;
    }

    .cars-empty__icon {
        width: 50px;
        height: 50px;
        margin: 0 auto 0.6rem;
        border: 1.5px solid var(--border);
        border-radius: 13px;
        color: #6366f1;
        background: #eef2ff;
        display: grid;
        place-items: center;
    }

    .cars-empty p {
        margin: 0;
        color: #6366f1;
        font-size: 0.92rem;
    }

    .cars-table-wrap {
        overflow-x: auto;
    }

    .cars-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 760px;
    }

    .cars-table thead th {
        text-align: left;
        white-space: nowrap;
        padding: 0.72rem 1rem;
        font-size: 0.68rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #6366f1;
        background: #f8faff;
        border-bottom: 1.5px solid var(--border);
    }

    .cars-table thead th:last-child,
    .cars-table td:last-child {
        text-align: right;
    }

    .cars-table tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background 0.15s;
    }

    .cars-table tbody tr:hover {
        background: #f8faff;
    }

    .cars-table tbody tr:last-child {
        border-bottom: none;
    }

    .cars-table td {
        padding: 0.86rem 1rem;
        vertical-align: middle;
        color: #1e1b4b;
        font-size: 0.88rem;
    }

    .cars-name {
        font-weight: 700;
        color: #1e1b4b;
    }

    .cars-variant {
        margin-top: 0.14rem;
        font-size: 0.77rem;
        color: #6366f1;
    }

    .cars-year {
        font-weight: 800;
        color: #4338ca;
    }

    .cars-price {
        font-weight: 800;
        color: #1e1b4b;
    }

    .cars-mileage {
        color: #6366f1;
    }

    .cars-badges {
        display: inline-flex;
        gap: 0.35rem;
        flex-wrap: wrap;
    }

    .cars-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.18rem 0.55rem;
        border-radius: 999px;
        font-size: 0.67rem;
        font-weight: 800;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .cars-badge--stock {
        background: rgba(59, 130, 246, 0.1);
        color: #1d4ed8;
        border: 1px solid rgba(59, 130, 246, 0.2);
    }

    .cars-badge--sold {
        background: rgba(16, 185, 129, 0.12);
        color: #047857;
        border: 1px solid rgba(16, 185, 129, 0.24);
    }

    .cars-badge--returned {
        background: rgba(245, 158, 11, 0.14);
        color: #b45309;
        border: 1px solid rgba(245, 158, 11, 0.24);
    }

    .cars-btn-edit {
        display: inline-flex;
        align-items: center;
        gap: 0.33rem;
        font-size: 0.79rem;
        font-weight: 700;
        color: #4338ca;
        text-decoration: none;
        border: 1.5px solid #c7d2fe;
        background: #eef2ff;
        border-radius: 8px;
        padding: 0.36rem 0.74rem;
        transition: color 0.18s, background 0.18s, border-color 0.18s;
    }

    .cars-btn-edit:hover {
        color: #312e81;
        background: #e0e7ff;
        border-color: #a5b4fc;
    }

    @@media (max-width: 980px) {
        .cars-metrics {
            grid-template-columns: 1fr;
        }

        .cars-hero__head {
            margin-bottom: 0.75rem;
        }
    }
</style>

<div class="cars-page">
    <section class="cars-hero">
        <div class="cars-hero__head">
            <div>
                <div class="cars-hero__label">Inventory</div>
                <h1 class="cars-hero__title">Cars Management</h1>
                <p class="cars-hero__sub">Search, review, and update every listing from one place.</p>
            </div>
            <a asp-controller="Admin" asp-action="AddCar" class="cars-btn-add">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add New Car
            </a>
        </div>

        <div class="cars-metrics">
            <div class="cars-metric">
                <span>Total Cars</span>
                <strong>@totalCars</strong>
            </div>
            <div class="cars-metric">
                <span>In Stock</span>
                <strong>@inStockCars</strong>
            </div>
            <div class="cars-metric">
                <span>Sold</span>
                <strong>@soldCars</strong>
            </div>
        </div>
    </section>

    <form method="get" asp-controller="Admin" asp-action="Cars" class="cars-filter">
        <div class="cars-filter__input-wrap">
            <svg class="cars-filter__icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text"
                   class="cars-filter__input"
                   name="search"
                   value="@Model.Search"
                   placeholder="Search by make, model, variant, color, VIN"
                   autocomplete="off" />
        </div>

        <button type="submit" class="cars-btn cars-btn--search">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            Search
        </button>

        @if (!string.IsNullOrWhiteSpace(Model.Search))
        {
            <a asp-controller="Admin" asp-action="Cars" class="cars-btn cars-btn--clear">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                Clear
            </a>
        }
    </form>

    <section class="cars-panel">
        <div class="cars-panel__head">
            <div style="display:flex;align-items:center;gap:0.55rem;flex-wrap:wrap;">
                <h2 class="cars-panel__title">Cars List</h2>
                @if (!string.IsNullOrWhiteSpace(Model.Search))
                {
                    <span class="cars-search-tag">
                        Searching: "@Model.Search"
                        <a asp-controller="Admin" asp-action="Cars" title="Clear search">Clear</a>
                    </span>
                }
            </div>
            <span class="cars-count">@Model.Cars.Count result@(Model.Cars.Count == 1 ? "" : "s")</span>
        </div>

        @if (Model.Cars.Count == 0)
        {
            <div class="cars-empty">
                <div class="cars-empty__icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 14.5V16a1 1 0 0 0 1 1h1a2 2 0 1 0 4 0h4a2 2 0 1 0 4 0h1a1 1 0 0 0 1-1v-1.5l-1.2-4.1A2 2 0 0 0 16.9 9H7.1a2 2 0 0 0-1.9 1.4L4 14.5Z"/>
                        <path d="M7.5 9 9 6.8A1.5 1.5 0 0 1 10.2 6h3.6A1.5 1.5 0 0 1 15 6.8L16.5 9"/>
                    </svg>
                </div>
                <p>No cars found@(!string.IsNullOrWhiteSpace(Model.Search) ? $" matching \"{Model.Search}\"" : "").</p>
                @if (!string.IsNullOrWhiteSpace(Model.Search))
                {
                    <a asp-controller="Admin" asp-action="Cars" class="cars-btn cars-btn--clear" style="margin-top:0.75rem;">Clear search</a>
                }
            </div>
        }
        else
        {
            <div class="cars-table-wrap">
                <table class="cars-table">
                    <thead>
                        <tr>
                            <th>Car</th>
                            <th>Year</th>
                            <th>Price</th>
                            <th>Mileage</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var car in Model.Cars)
                        {
                            <tr>
                                <td>
                                    <div class="cars-name">@car.Make @car.Model</div>
                                    @if (!string.IsNullOrWhiteSpace(car.Variant))
                                    {
                                        <div class="cars-variant">@car.Variant</div>
                                    }
                                </td>
                                <td><span class="cars-year">@car.Year</span></td>
                                <td><span class="cars-price">$@car.Price.ToString("N2")</span></td>
                                <td><span class="cars-mileage">@car.MileageKm.ToString("N0") km</span></td>
                                <td>
                                    <div class="cars-badges">
                                        @if (car.IsSold)
                                        {
                                            <span class="cars-badge cars-badge--sold">Sold</span>
                                        }
                                        else
                                        {
                                            <span class="cars-badge cars-badge--stock">In Stock</span>
                                        }
                                        @if (car.IsReturned)
                                        {
                                            <span class="cars-badge cars-badge--returned">Returned</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <a asp-controller="Admin"
                                       asp-action="EditCar"
                                       asp-route-id="@car.Id"
                                       class="cars-btn-edit">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                        Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>
