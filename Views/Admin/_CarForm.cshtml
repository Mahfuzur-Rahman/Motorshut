@model MotorsHut.Models.Admin.CarFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="Make" class="form-label"></label>
        <input asp-for="Make" class="form-control" />
        <span asp-validation-for="Make" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Model" class="form-label"></label>
        <input asp-for="Model" class="form-control" />
        <span asp-validation-for="Model" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Variant" class="form-label"></label>
        <input asp-for="Variant" class="form-control" />
        <span asp-validation-for="Variant" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Year" class="form-label"></label>
        <input asp-for="Year" class="form-control" />
        <span asp-validation-for="Year" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="MileageKm" class="form-label"></label>
        <input asp-for="MileageKm" class="form-control" />
        <span asp-validation-for="MileageKm" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="FuelType" class="form-label"></label>
        <select asp-for="FuelType" class="form-select">
            <option value="">Select Fuel Type</option>
            <option value="Petrol">Petrol</option>
            <option value="Diesel">Diesel</option>
            <option value="Hybrid">Hybrid</option>
            <option value="Electric">Electric</option>
            <option value="CNG">CNG</option>
        </select>
        <span asp-validation-for="FuelType" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Transmission" class="form-label"></label>
        <select asp-for="Transmission" class="form-select">
            <option value="">Select Transmission</option>
            <option value="Auto">Auto</option>
            <option value="Manual">Manual</option>
            <option value="CVT">CVT</option>
            <option value="DCT">DCT</option>
        </select>
        <span asp-validation-for="Transmission" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Color" class="form-label"></label>
        <input asp-for="Color" class="form-control" />
        <span asp-validation-for="Color" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Vin" class="form-label"></label>
        <input asp-for="Vin" class="form-control" />
        <span asp-validation-for="Vin" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="ShortDescription" class="form-label"></label>
        <textarea asp-for="ShortDescription" class="form-control" rows="3" placeholder="Write a short card description..."></textarea>
        <span asp-validation-for="ShortDescription" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="InStock" class="form-label"></label>
        <input asp-for="InStock" class="form-control" min="0" />
        <span asp-validation-for="InStock" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="TotalSold" class="form-label"></label>
        <input asp-for="TotalSold" class="form-control" min="0" />
        <span asp-validation-for="TotalSold" class="text-danger"></span>
    </div>
</div>
