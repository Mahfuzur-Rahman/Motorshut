<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <title>@ViewData["Title"] — Motors Hut Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        :root {
            /* Sidebar — Midnight Indigo gradient */
            --sidebar-grad:    linear-gradient(170deg, #1e1b4b 0%, #312e81 50%, #4338ca 100%);
            --sidebar-border:  rgba(255, 255, 255, 0.09);
            --sidebar-hover:   rgba(255, 255, 255, 0.09);
            --sidebar-active:  rgba(255, 255, 255, 0.16);
            --sidebar-text:    #ffffff;
            --sidebar-muted:   #a5b4fc;
            --sidebar-label:   #818cf8;

            /* Content area */
            --bg:              #eef2ff;
            --surface:         #ffffff;
            --border:          #e0e7ff;
            --border-hover:    #a5b4fc;
            --text:            #1e1b4b;
            --text-soft:       #3730a3;
            --muted:           #818cf8;
            --muted2:          #6366f1;
            --accent:          #4338ca;
            --accent-light:    rgba(67, 56, 202, 0.1);

            --sidebar-w:       262px;
            --topbar-h:        64px;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        html, body {
            height: 100%;
            font-family: 'Nunito', sans-serif;
            background: var(--bg);
            color: var(--text);
            font-size: 16px;
            line-height: 1.6;
        }

        /* ── Shell ── */
        .adm-shell {
            display: grid;
            grid-template-columns: var(--sidebar-w) 1fr;
            min-height: 100vh;
        }

        /* ══ SIDEBAR ══ */
        .adm-sidebar {
            grid-column: 1;
            grid-row: 1;
            background: var(--sidebar-grad);
            border-right: 1px solid var(--sidebar-border);
            display: flex;
            flex-direction: column;
            position: sticky;
            top: 0;
            height: 100vh;
            overflow-y: auto;
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,0.12) transparent;
        }

        /* Shimmer line at top */
        .adm-sidebar::after {
            content: '';
            position: fixed;
            top: 0; left: 0;
            width: var(--sidebar-w);
            height: 3px;
            background: linear-gradient(90deg, #a5b4fc, #818cf8, #c7d2fe, transparent);
            z-index: 1;
        }

        /* Brand */
        .adm-brand {
            padding: 1.5rem 1.4rem 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.85rem;
            border-bottom: 1px solid var(--sidebar-border);
        }

        .adm-brand__icon {
            width: 42px; height: 42px;
            background: rgba(255, 255, 255, 0.15);
            border: 1.5px solid rgba(255, 255, 255, 0.25);
            border-radius: 12px;
            display: grid;
            place-items: center;
            flex-shrink: 0;
            box-shadow: 0 4px 18px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255,255,255,0.2);
        }

        .adm-brand__icon svg { width: 22px; height: 22px; color: #fff; }

        .adm-brand__name {
            font-size: 1.2rem;
            font-weight: 800;
            color: #fff;
            display: block;
            letter-spacing: 0.01em;
        }

        .adm-brand__tag {
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--sidebar-muted);
            display: block;
            margin-top: 1px;
        }

        /* Nav */
        .adm-nav {
            flex: 1;
            padding: 1rem 0.85rem;
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
        }

        .adm-nav__label {
            font-size: 0.68rem;
            font-weight: 800;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--sidebar-label);
            padding: 0.65rem 0.7rem 0.3rem;
            margin-top: 0.3rem;
        }

        .adm-nav__link {
            display: flex;
            align-items: center;
            gap: 0.78rem;
            padding: 0.7rem 0.9rem;
            border-radius: 10px;
            font-size: 0.97rem;
            font-weight: 600;
            color: var(--sidebar-muted);
            text-decoration: none;
            transition: color 0.18s, background 0.18s;
            position: relative;
            border: 1px solid transparent;
        }

        .adm-nav__link:hover {
            color: #fff;
            background: var(--sidebar-hover);
        }

        .adm-nav__link.active {
            color: #fff;
            background: var(--sidebar-active);
            border-color: rgba(255, 255, 255, 0.18);
            font-weight: 700;
        }

        .adm-nav__link.active .adm-nav__icon { color: #c7d2fe; }

        .adm-nav__link.active::before {
            content: '';
            position: absolute;
            left: 0; top: 18%; bottom: 18%;
            width: 3.5px;
            background: linear-gradient(to bottom, #c7d2fe, #a5b4fc);
            border-radius: 0 4px 4px 0;
        }

        .adm-nav__icon {
            width: 19px; height: 19px;
            flex-shrink: 0;
            color: var(--sidebar-label);
            transition: color 0.18s;
        }

        .adm-nav__link:hover .adm-nav__icon { color: #c7d2fe; }

        .adm-nav__sep {
            height: 1px;
            background: rgba(255, 255, 255, 0.08);
            margin: 0.6rem 0.4rem;
        }

        .adm-nav__form { display: contents; }

        .adm-nav__btn {
            width: 100%;
            background: none;
            border: 1px solid transparent;
            cursor: pointer;
            text-align: left;
            display: flex;
            align-items: center;
            gap: 0.78rem;
            padding: 0.7rem 0.9rem;
            border-radius: 10px;
            font-size: 0.97rem;
            font-weight: 600;
            color: var(--sidebar-muted);
            font-family: 'Nunito', sans-serif;
            transition: color 0.18s, background 0.18s;
        }

        .adm-nav__btn:hover {
            color: #fca5a5;
            background: rgba(252, 165, 165, 0.1);
        }

        .adm-nav__btn:hover .adm-nav__icon { color: #fca5a5; }

        /* Sidebar foot */
        .adm-sidebar__foot {
            padding: 1rem 1.1rem;
            border-top: 1px solid var(--sidebar-border);
            display: flex;
            align-items: center;
            gap: 0.78rem;
            background: rgba(0, 0, 0, 0.15);
        }

        .adm-user-avatar {
            width: 38px; height: 38px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.18);
            border: 2px solid rgba(255, 255, 255, 0.3);
            display: grid;
            place-items: center;
            font-weight: 800;
            font-size: 0.82rem;
            color: #fff;
            flex-shrink: 0;
        }

        .adm-user-info { min-width: 0; }

        .adm-user-name {
            font-size: 0.9rem;
            font-weight: 700;
            color: #fff;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            display: block;
        }

        .adm-user-role {
            font-size: 0.68rem;
            color: var(--sidebar-muted);
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        /* ══ MAIN ══ */
        .adm-main {
            grid-column: 2;
            grid-row: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background: var(--bg);
        }

        /* Topbar */
        .adm-topbar {
            position: sticky;
            top: 0; z-index: 100;
            height: var(--topbar-h);
            background: rgba(238, 242, 255, 0.92);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1.5px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            gap: 1rem;
        }

        .adm-topbar__left {
            display: flex;
            align-items: center;
            gap: 0.7rem;
            min-width: 0;
        }

        .adm-page-title {
            display: flex;
            align-items: center;
            gap: 0.55rem;
            font-size: 0.97rem;
            font-weight: 700;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .adm-page-title__prefix { color: var(--muted2); font-weight: 500; }
        .adm-page-title__sep    { color: var(--muted); }

        .adm-page-title__icon {
            width: 28px; height: 28px;
            background: var(--accent-light);
            border: 1.5px solid rgba(99, 102, 241, 0.25);
            border-radius: 8px;
            display: grid;
            place-items: center;
            flex-shrink: 0;
        }

        .adm-page-title__icon svg { width: 14px; height: 14px; color: var(--accent); }

        .adm-topbar__right {
            display: flex;
            align-items: center;
            gap: 0.9rem;
            flex-shrink: 0;
        }

        .adm-topbar__user {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            padding: 0.4rem 0.9rem 0.4rem 0.55rem;
            border: 1.5px solid var(--border);
            border-radius: 999px;
            font-size: 0.88rem;
            font-weight: 600;
            color: var(--text-soft);
            background: var(--surface);
        }

        .adm-topbar__dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: #4ade80;
            box-shadow: 0 0 0 3px rgba(74, 222, 128, 0.22);
            flex-shrink: 0;
        }

        .adm-topbar__bell {
            width: 38px; height: 38px;
            background: var(--surface);
            border: 1.5px solid var(--border);
            border-radius: 10px;
            display: grid;
            place-items: center;
            color: var(--muted2);
            cursor: pointer;
            transition: color 0.18s, background 0.18s, border-color 0.18s;
            text-decoration: none;
        }

        .adm-topbar__bell:hover {
            color: var(--accent);
            background: var(--accent-light);
            border-color: var(--border-hover);
        }

        .adm-topbar__menu {
            display: none;
            width: 38px; height: 38px;
            background: var(--surface);
            border: 1.5px solid var(--border);
            border-radius: 10px;
            place-items: center;
            color: var(--text-soft);
            cursor: pointer;
            flex-direction: column;
            justify-content: center;
            gap: 5px;
            padding: 9px 10px;
        }

        .adm-topbar__menu span {
            display: block;
            height: 1.8px;
            width: 100%;
            background: currentColor;
            border-radius: 2px;
            transition: all 0.22s;
        }

        /* Content */
        .adm-content {
            flex: 1;
            padding: 2rem 2rem 3rem;
        }

        /* Overlay */
        .adm-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(30, 27, 75, 0.4);
            z-index: 299;
            backdrop-filter: blur(3px);
        }

        .adm-overlay.open { display: block; }

        /* ── Responsive ── */
        @@media (max-width: 900px) {
            .adm-shell { grid-template-columns: 1fr; }
            .adm-main  { grid-column: 1; grid-row: 1; }

            .adm-sidebar {
                position: fixed;
                left: -100%; top: 0;
                z-index: 300;
                width: var(--sidebar-w);
                transition: left 0.28s cubic-bezier(0.4, 0, 0.2, 1);
                box-shadow: 8px 0 48px rgba(30, 27, 75, 0.4);
                grid-column: unset; grid-row: unset;
            }

            .adm-sidebar.open { left: 0; }
            .adm-topbar__menu { display: flex; }
        }
    </style>
</head>

<body>
    <div class="adm-shell">

        <!-- ── Sidebar ── -->
        <aside class="adm-sidebar" id="admSidebar">

            <div class="adm-brand">
                <div class="adm-brand__icon">
                    <svg viewBox="0 0 24 24" fill="none">
                        <path d="M4 14.5V16a1 1 0 0 0 1 1h1a2 2 0 1 0 4 0h4a2 2 0 1 0 4 0h1a1 1 0 0 0 1-1v-1.5l-1.2-4.1A2 2 0 0 0 16.9 9H7.1a2 2 0 0 0-1.9 1.4L4 14.5Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                        <path d="M7.5 9 9 6.8A1.5 1.5 0 0 1 10.2 6h3.6A1.5 1.5 0 0 1 15 6.8L16.5 9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                        <circle cx="8" cy="17" r="1.2" fill="currentColor"/>
                        <circle cx="16" cy="17" r="1.2" fill="currentColor"/>
                    </svg>
                </div>
                <div>
                    <span class="adm-brand__name">Motors Hut</span>
                    <span class="adm-brand__tag">Admin Panel</span>
                </div>
            </div>

            <nav class="adm-nav">

                <div class="adm-nav__label">Main</div>

                <a class="adm-nav__link @(Context.Request.Path.Value?.Contains("/admin/dashboard", StringComparison.OrdinalIgnoreCase) == true ? "active" : string.Empty)"
                   asp-controller="Admin" asp-action="Dashboard">
                    <svg class="adm-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/>
                    </svg>
                    Dashboard
                </a>

                <a class="adm-nav__link @(Context.Request.Path.Value?.Contains("/admin/cars", StringComparison.OrdinalIgnoreCase) == true ? "active" : string.Empty)"
                   asp-controller="Admin" asp-action="Cars">
                    <svg class="adm-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 14.5V16a1 1 0 0 0 1 1h1a2 2 0 1 0 4 0h4a2 2 0 1 0 4 0h1a1 1 0 0 0 1-1v-1.5l-1.2-4.1A2 2 0 0 0 16.9 9H7.1a2 2 0 0 0-1.9 1.4L4 14.5Z"/>
                        <path d="M7.5 9 9 6.8A1.5 1.5 0 0 1 10.2 6h3.6A1.5 1.5 0 0 1 15 6.8L16.5 9"/>
                    </svg>
                    Cars
                </a>

                <div class="adm-nav__label">Settings</div>

                <a class="adm-nav__link @(Context.Request.Path.Value?.Contains("/admin/register-admin", StringComparison.OrdinalIgnoreCase) == true ? "active" : string.Empty)"
                   asp-controller="Admin" asp-action="RegisterAdmin">
                    <svg class="adm-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>
                    </svg>
                    Register Admin
                </a>

                <a class="adm-nav__link @(Context.Request.Path.Value?.Contains("/change-password", StringComparison.OrdinalIgnoreCase) == true ? "active" : string.Empty)"
                   asp-controller="Account" asp-action="ChangePassword">
                    <svg class="adm-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    Change Password
                </a>

                <div class="adm-nav__sep"></div>

                <a class="adm-nav__link" asp-controller="Home" asp-action="Index">
                    <svg class="adm-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12L12 3l9 9"/><path d="M9 21V12h6v9"/>
                    </svg>
                    Back to Site
                </a>

                <form asp-controller="Account" asp-action="Logout" method="post" class="adm-nav__form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="adm-nav__btn">
                        <svg class="adm-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                        Logout
                    </button>
                </form>

            </nav>

            <div class="adm-sidebar__foot">
                <div class="adm-user-avatar" id="admAvatarInitial">AD</div>
                <div class="adm-user-info">
                    <span class="adm-user-name" id="admUserName">@User.Identity?.Name</span>
                    <span class="adm-user-role">Administrator</span>
                </div>
            </div>
        </aside>

        <!-- ── Main ── -->
        <div class="adm-main">

            <header class="adm-topbar">
                <div class="adm-topbar__left">
                    <button class="adm-topbar__menu" id="admMenuBtn" aria-label="Open sidebar">
                        <span></span><span></span><span></span>
                    </button>
                    <div class="adm-page-title">
                        <div class="adm-page-title__icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/>
                            </svg>
                        </div>
                        <span class="adm-page-title__prefix">Admin</span>
                        <svg class="adm-page-title__sep" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
                        <span>@ViewData["Title"]</span>
                    </div>
                </div>

                <div class="adm-topbar__right">
                    <a href="#" class="adm-topbar__bell" aria-label="Notifications">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                    </a>
                    <div class="adm-topbar__user">
                        <span class="adm-topbar__dot"></span>
                        <span id="admTopbarName">@User.Identity?.Name</span>
                    </div>
                </div>
            </header>

            <main class="adm-content">
                @RenderBody()
            </main>
        </div>

    </div><!-- /.adm-shell -->

    <div class="adm-overlay" id="admOverlay"></div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <script>
            Swal.fire({
                toast: true, position: "top-end", icon: "success",
                title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(successMessage)),
                showConfirmButton: false, timer: 2200, timerProgressBar: true,
                background: '#ffffff', color: '#1e1b4b', iconColor: '#4338ca'
            });
        </script>
    }
    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <script>
            Swal.fire({
                toast: true, position: "top-end", icon: "error",
                title: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(errorMessage)),
                showConfirmButton: false, timer: 2600, timerProgressBar: true,
                background: '#ffffff', color: '#1e1b4b', iconColor: '#dc2626'
            });
        </script>
    }

    <script>
        const sidebar = document.getElementById('admSidebar');
        const overlay = document.getElementById('admOverlay');
        const menuBtn = document.getElementById('admMenuBtn');

        function openSidebar()  { sidebar.classList.add('open');    overlay.classList.add('open'); }
        function closeSidebar() { sidebar.classList.remove('open'); overlay.classList.remove('open'); }

        menuBtn?.addEventListener('click', () =>
            sidebar.classList.contains('open') ? closeSidebar() : openSidebar()
        );
        overlay?.addEventListener('click', closeSidebar);

        const name = document.getElementById('admUserName')?.textContent?.trim() || '';
        const initials = name.split(/[\s@@.]/).filter(Boolean).slice(0, 2).map(w => w[0].toUpperCase()).join('') || 'AD';
        const avatarEl = document.getElementById('admAvatarInitial');
        if (avatarEl) avatarEl.textContent = initials;
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
